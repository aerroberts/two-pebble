{
  "name": "@two-pebble/pebble",
  "version": "0.1.0",
  "description": "Thread and cell primitives for model context and provider integrations.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./capabilities": {
      "types": "./src/capabilities/index.ts",
      "import": "./src/capabilities/index.ts"
    },
    "./frameworks": {
      "types": "./src/frameworks/index.ts",
      "import": "./src/frameworks/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "ci": "bun lint && bun run guard && bun run build && bun run typecheck && bun run test",
    "guard": "guardrails",
    "lint": "biome check --write .",
    "test": "bun test src",
    "test:coverage": "bun test --coverage src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.128",
    "@openai/codex-sdk": "0.128.0",
    "@two-pebble/datatypes": "workspace:*",
    "@two-pebble/events": "workspace:*",
    "@toon-format/toon": "^2.1.0",
    "diff": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@two-pebble/guardrails": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/diff": "^7.0.2",
    "@types/node": "22.19.17"
  }
}
