    "zustand": "5.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@two-pebble/daemon": "workspace:*",
    "@two-pebble/guardrails": "workspace:*",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "happy-dom": "^20.0.10",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
