{
  "inherit": "@group/guardrails-typescript",
  "structure": [
    // Protocol operation modules stay flat and domain-named so the bridge contract is visible in one directory.
    // Import allowlists are not supported by structure-only guardrails; keep imports limited to datatypes, pebble, task-events, and explicit sibling protocol dependencies.
    {
      "find": "src/protocol/*",
      "recommendation": "Protocol operation modules stay flat and domain-named so the bridge contract is visible in one directory.",
      "asserts": {
        "type": "file"
      },
      "code": [
        {
          "find": "export/interface",
          "recommendation": "Protocol operation modules expose their wire contract through exported interfaces.",
          "asserts": {
            "exists": true
          }
        }
      ]
    },

    // Protocol operation modules must not use nested folders; encode hierarchy in the file name.
    {
      "find": "src/protocol/*/*",
      "recommendation": "Protocol operation modules must not use nested folders; encode hierarchy in the file name.",
      "asserts": {
        "exists": false
      }
    },

    // Each task event kind lives in its own flat file with a single self-contained interface so wire shapes are easy to scan.
    // Import allowlists and literal `export type` string checks are not supported by structure-only guardrails.
    {
      "find": ["src/task-events/status.ts", "src/task-events/delegated.ts", "src/task-events/undelegated.ts"],
      "recommendation": "Each task event kind lives in its own flat file with a single self-contained interface so wire shapes are easy to scan.",
      "asserts": {
        "exists": true,
        "type": "file"
      },
      "code": [
        {
          "find": "export/interface",
          "recommendation": "Each task event kind exports a self-contained interface.",
          "asserts": {
            "exists": true
          }
        },
        {
          "find": "export/type",
          "recommendation": "Task event kind files should not export type aliases; keep shared unions in task-events/types.ts.",
          "asserts": {
            "exists": false
          }
        }
      ]
    },

    // task-events/index.ts is a flat re-export barrel for the per-kind event interfaces and the TaskEventRecord union.
    // Re-export path allowlists are not supported by structure-only guardrails; keep this barrel limited to status, delegated, undelegated, and types.
    {
      "find": "src/task-events/index.ts",
      "recommendation": "task-events/index.ts is a flat re-export barrel for the per-kind event interfaces and the TaskEventRecord union.",
      "asserts": {
        "exists": true,
        "type": "file"
      }
    },

    // task-events/types.ts holds the discriminated TaskEventRecord union derived from the per-kind interfaces.
    // Import allowlists are not supported by structure-only guardrails; keep imports limited to status, delegated, and undelegated.
    {
      "find": "src/task-events/types.ts",
      "recommendation": "task-events/types.ts holds the discriminated TaskEventRecord union derived from the per-kind interfaces.",
      "asserts": {
        "exists": true,
        "type": "file"
      }
    },

    // Task event modules must not use nested folders.
    {
      "find": "src/task-events/*/*",
      "recommendation": "Task event modules must not use nested folders.",
      "asserts": {
        "exists": false
      }
    }
  ]
}
