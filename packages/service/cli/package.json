{
  "name": "@two-pebble/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "peb": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --outfile=dist/index.js && chmod +x dist/index.js",
    "ci": "bun lint && bun run guard && bun run build && bun run typecheck && bun run test",
    "dev": "bun run build && bun link",
    "link": "bun link",
    "guard": "bunx guardrails",
    "lint": "biome check --write .",
    "test": "bun -e \"console.log('No CLI tests configured')\"",
    "test:coverage": "bun -e \"console.log('No CLI tests configured')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@two-pebble/datatypes": "workspace:*",
    "@two-pebble/pebble": "workspace:*",
    "@two-pebble/protocol": "workspace:*",
    "@two-pebble/ws-bridge": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@two-pebble/guardrails": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/node": "22.19.17"
  }
}
