{
  "name": "@two-pebble/guardrails",
  "version": "0.1.0",
  "description": "Vendored guardrails CLI for the two-pebble monorepo.",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "guardrails": "./bin/guardrails.mjs"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit",
    "ci": "bun lint && bun run guard && bun run build && bun run typecheck && bun run test",
    "guard": "bun run src/runner/cli.ts",
    "lint": "biome check --write .",
    "test": "find src -name '*.test.ts' -not -path '*/fixtures/*' -print0 | xargs -0 bun test",
    "test:coverage": "find src -name '*.test.ts' -not -path '*/fixtures/*' -print0 | xargs -0 bun test --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@two-pebble/traversal": "workspace:*",
    "picocolors": "1.1.1",
    "tinyglobby": "0.2.15",
    "typescript": "6.0.2"
  }
}
