{
  "inherit": ["guardrails-package", "guardrails-typescript"],
  "structure": [
    // Capability folders keep their only top-level TypeScript entrypoint in
    // capability.ts. Schemas, helpers, tests, and prompt text live under
    // tools/, prompts/, tests/, or utils/.
    // Each capability folder should expose its runtime entrypoint as capability.ts.
    {
      "find": "src/capabilities/*/capability.ts",
      "asserts": {
        "exists": true,
        "type": "file",
        // Capabilities own state, lifecycle hooks, and tool registration order only.
        // Tool construction belongs in tools/<tool-name>/handler.ts so schemas,
        // descriptions, and invoke behavior stay together and are easy to review.
        "content": {
          "lacks": ["new NativeTool", "new CliTool", "new AgentTool", ".onInvoke("]
        }
      }
    },
    // Every capability owns a system prompt file. The required
    // RegisterHookResult.system type enforces that hookOnRegister supplies
    // a system string at compile time.
    {
      "find": "src/capabilities/*/prompts/system.md",
      "asserts": {
        "exists": true,
        "type": "file"
      }
    },
    // Capability folders must not contain direct TypeScript files other than capability.ts. Move schemas, helpers, tests, and prompt text into subfolders.
    {
      "find": "src/capabilities/*/*.ts",
      "exclude": "src/capabilities/*/capability.ts",
      "asserts": {
        "exists": false
      }
    },
    // Capability tool modules live one folder per tool. Do not put schemas,
    // indexes, or shared modules directly under tools/; move shared helpers
    // to utils/ and keep each concrete tool in tools/<tool-name>/handler.ts.
    {
      "find": "src/capabilities/*/tools/*.ts",
      "asserts": {
        "exists": false
      }
    },
    // Every concrete tool handler owns the tool's schema, creates the tool,
    // and attaches its invoke behavior. The exported builder accepts the
    // capability object so handlers can use capability state without reaching
    // around the capability abstraction.
    {
      "find": "src/capabilities/*/tools/*/handler.ts",
      "asserts": {
        "exists": true,
        "type": "file",
        "content": {
          "includes": ["const schema", "export function build", ".onInvoke"]
        }
      }
    },
    // Capability prompt folders must contain Markdown files only.
    {
      "find": "src/capabilities/*/prompts/*",
      "exclude": "src/capabilities/*/prompts/*.md",
      "asserts": {
        "exists": false
      }
    },

    // Agent trace payload contracts live in their own folder so durable runtime events have explicit ownership.
    // The traversal layer currently returns file nodes for glob matches, not folder nodes, so the old folder type
    // check is represented by requiring trace files inside the folder.
    // Agent trace payload contracts live in their own folder so durable runtime events have explicit ownership.
    {
      "find": "src/traces/agent-traces/*.ts",
      "asserts": {
        "exists": true,
        "type": "file"
      }
    },

    // Each agent trace file should remain a self-contained exported interface. The old guard required the literal
    // `export interface PebbleAgent` string and restricted imports to ../../thread or ../../thread/index. The
    // structure-only runner has no string-contains or allowed-import-path assertions, so this approximates the
    // contract by requiring an exported interface while preserving the stronger steering in this comment.
    // Each agent trace file must be a self-contained exported interface. Trace payloads are protocol-like contracts and should not be hidden in generic agent types. Imports should stay limited to ../../thread or ../../thread/index.
    {
      "find": "src/traces/agent-traces/*.ts",
      "asserts": {
        "exists": true,
        "type": "file"
      },
      "code": [
        {
          "find": "export/interface",
          "asserts": {
            "matches": {
              "min": 1
            }
          }
        }
      ]
    },

    // Agent trace interfaces stay one file deep so the trace catalog is scanable.
    // Agent trace interfaces stay one file deep so the trace catalog is scanable.
    {
      "find": "src/traces/agent-traces/*/*",
      "asserts": {
        "exists": false
      }
    }
  ]
}
