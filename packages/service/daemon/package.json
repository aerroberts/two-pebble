{
  "name": "@two-pebble/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "ci": "bun lint && bun run guard && bun run build && bun run typecheck && bun run test",
    "dev": "bun --watch scripts/daemon.ts",
    "start": "bun scripts/daemon.ts",
    "guard": "guard",
    "lint": "biome check --write .",
    "test": "bun test src",
    "test:coverage": "bun test --coverage src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@two-pebble/datastore": "workspace:*",
    "@two-pebble/datatypes": "workspace:*",
    "@two-pebble/logger": "workspace:*",
    "@two-pebble/metrics": "workspace:*",
    "@two-pebble/names": "workspace:*",
    "@two-pebble/pebble": "workspace:*",
    "@two-pebble/protocol": "workspace:*",
    "@two-pebble/tasks": "workspace:*",
    "@two-pebble/ws-bridge": "workspace:*"
  },
  "devDependencies": {}
}
